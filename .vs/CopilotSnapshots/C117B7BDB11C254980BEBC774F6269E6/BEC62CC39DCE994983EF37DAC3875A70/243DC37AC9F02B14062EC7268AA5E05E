name: .NET Build

on:
  push:
  pull_request:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4
    - name: Check greeting WAV exists
      run: |
        if [ -f assets/greeting.wav ]; then
          echo "assets/greeting.wav present"
        else
          echo "ERROR: assets/greeting.wav is missing. Add a greeting WAV to assets/greeting.wav or generate one using the provided scripts.";
          exit 1
        fi
    - name: Setup .NET
      uses: actions/setup-dotnet@v3
      with:
        dotnet-version: '8.0.x'
    - name: Restore
      run: dotnet restore
    - name: Build
      run: dotnet build --no-restore --configuration Release
    - name: Run tests
      run: |
        dotnet test --no-build --verbosity normal
