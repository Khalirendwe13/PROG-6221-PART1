using System;
using System.Threading.Tasks;

namespace CyberAwarenessBot
{
    internal class Program
    {
        static async Task Main(string[] args)
        {
            ConsoleUI.ClearAndDrawHeader();
            await VoiceGreetingHandler.PlayGreetingAsync("assets/greeting.wav");

            ConsoleUI.WriteColoredLine("Welcome to the Cybersecurity Awareness Bot!", ConsoleColor.Cyan);
            ConsoleUI.WriteColoredLine("Type 'help' to see available runtime commands.", ConsoleColor.DarkCyan);
            ConsoleUI.WriteColoredLine("Please enter your name:", ConsoleColor.Yellow);

            string? name = ConsoleUI.ReadNonEmptyLine("Name");
            var bot = new Bot { UserName = name };

            ConsoleUI.TypeWrite($"Hello {bot.UserName}! I'm your Cybersecurity Awareness assistant.\n", 25);
            ConsoleUI.WriteDivider();

            // Present topic options to the user
            ConsoleUI.WriteColoredLine("Choose a topic to learn about:", ConsoleColor.Green);
            ConsoleUI.WriteColoredLine("  1. Password Safety", ConsoleColor.Yellow);
            ConsoleUI.WriteColoredLine("  2. Phishing", ConsoleColor.Yellow);
            ConsoleUI.WriteColoredLine("  3. Safe Browsing", ConsoleColor.Yellow);
            ConsoleUI.WriteColoredLine("Enter the number of your choice:", ConsoleColor.Cyan);

            string? topicChoice = Console.ReadLine();
            string topicResponse = string.Empty;
            switch (topicChoice)
            {
                case "1":
                    topicResponse = bot.GetResponse("password", out _);
                    break;
                case "2":
                    topicResponse = bot.GetResponse("phishing", out _);
                    break;
                case "3":
                    topicResponse = bot.GetResponse("safe browsing", out _);
                    break;
                default:
                    topicResponse = "Invalid choice. You can ask me about password safety, phishing, or safe browsing at any time.";
                    break;
            }
            ConsoleUI.TypeWrite(topicResponse + "\n", 18);
            ConsoleUI.WriteDivider();

            bool running = true;
            while (running)
            {
                ConsoleUI.WriteColoredLine("Ask me a question (or type 'exit' to quit):", ConsoleColor.Green);
                string input = Console.ReadLine()?.Trim() ?? "";

                if (string.IsNullOrWhiteSpace(input))
                {
                    ConsoleUI.WriteColoredLine("I didn't quite understand that. Could you rephrase?", ConsoleColor.Red);
                    continue;
                }

                if (input.Equals("exit", StringComparison.OrdinalIgnoreCase))
                {
                    running = false;
                    ConsoleUI.TypeWrite("Goodbye! Stay safe online.\n", 20);
                    continue;
                }

                string response = bot.GetResponse(input);
                ConsoleUI.TypeWrite(response + "\n", 18);
            }
        }
    }
}
