using System;
using System.Threading.Tasks;

namespace CyberAwarenessBot
{
    internal class Program
    {
        static async Task Main(string[] args)
        {
            ConsoleUI.ClearAndDrawHeader();
            await VoiceGreetingHandler.PlayGreetingAsync("assets/greeting.wav");

            ConsoleUI.WriteColoredLine("Welcome to the Cybersecurity Awareness Bot!", ConsoleColor.Cyan);
            ConsoleUI.WriteColoredLine("Please enter your name:", ConsoleColor.Yellow);
            string name = ConsoleUI.ReadNonEmptyLine("Name");

            var bot = new Bot { UserName = name }; 
            ConsoleUI.TypeWrite($"Hello {bot.UserName}! I'm your Cybersecurity Awareness assistant.\n", 25);

            bool running = true;
            while (running)
            {
                ConsoleUI.WriteColoredLine("Ask me a question (or type 'exit' to quit):", ConsoleColor.Green);
                string input = Console.ReadLine()?.Trim() ?? "";

                if (string.IsNullOrWhiteSpace(input))
                {
                    ConsoleUI.WriteColoredLine("I didn't quite understand that. Could you rephrase?", ConsoleColor.Red);
                    continue;
                }

                if (input.Equals("exit", StringComparison.OrdinalIgnoreCase))
                {
                    running = false;
                    ConsoleUI.TypeWrite("Goodbye! Stay safe online.\n", 20);
                    continue;
                }

                string response = bot.GetResponse(input);
                ConsoleUI.TypeWrite(response + "\n", 18);
            }
        }
    }
}
