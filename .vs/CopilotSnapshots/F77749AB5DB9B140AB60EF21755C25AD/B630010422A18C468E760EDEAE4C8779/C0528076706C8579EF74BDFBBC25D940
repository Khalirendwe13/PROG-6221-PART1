using System;
using System.IO;
using System.Reflection;
using System.Threading.Tasks;

namespace CyberAwarenessBot
{
    public static class VoiceRecordingHandler
    {
        private static bool _isAvailable = false;

        static VoiceRecordingHandler()
        {
            // Check if System.Audio is available (Windows only)
            try
            {
                Assembly.Load("System.Audio");
                _isAvailable = true;
            }
            catch
            {
                _isAvailable = false;
            }
        }

        public static bool IsAvailable => _isAvailable;

        /// <summary>
        /// Records audio from the microphone for a specified duration and saves it as a WAV file.
        /// </summary>
        /// <param name="outputPath">Path where the WAV file will be saved</param>
        /// <param name="durationSeconds">Duration of recording in seconds</param>
        /// <returns>True if recording succeeded, false otherwise</returns>
        public static async Task<bool> RecordVoiceAsync(string outputPath, int durationSeconds = 5)
        {
            if (!_isAvailable)
            {
                ConsoleUI.WriteColoredLine("Voice recording is not available on this system.", ConsoleColor.Red);
                return false;
            }

            try
            {
                Directory.CreateDirectory(Path.GetDirectoryName(outputPath) ?? "assets");

                // Try to use NAudio for recording if available, otherwise use WaveInEvent via reflection
                return await RecordUsingReflectionAsync(outputPath, durationSeconds);
            }
            catch (Exception ex)
            {
                ConsoleUI.WriteColoredLine($"Recording failed: {ex.Message}", ConsoleColor.Red);
                return false;
            }
        }

        private static async Task<bool> RecordUsingReflectionAsync(string outputPath, int durationSeconds)
        {
            try
            {
                // Load NAudio assembly if available
                Assembly? nAudioAsm = null;
                try
                {
                    nAudioAsm = Assembly.Load("NAudio.Core");
                }
                catch
                {
                    // NAudio not available, will fall back to System.Media
                }

                if (nAudioAsm != null)
                {
                    return await RecordWithNAudioAsync(outputPath, durationSeconds);
                }
                else
                {
                    return await RecordWithSystemMediaAsync(outputPath, durationSeconds);
                }
            }
            catch (Exception ex)
            {
                ConsoleUI.WriteColoredLine($"Reflection-based recording failed: {ex.Message}", ConsoleColor.Red);
                return false;
            }
        }

        private static async Task<bool> RecordWithNAudioAsync(string outputPath, int durationSeconds)
        {
            try
            {
                var waveInType = Type.GetType("NAudio.Wave.WaveInEvent, NAudio.Core");
                var waveFileWriterType = Type.GetType("NAudio.Wave.WaveFileWriter, NAudio.Core");

                if (waveInType == null || waveFileWriterType == null)
                {
                    return false;
                }

                object? waveIn = Activator.CreateInstance(waveInType);
                if (waveIn == null) return false;

                // Create WaveFileWriter
                var waveFileWriter = Activator.CreateInstance(waveFileWriterType, outputPath, 
                    waveInType.GetProperty("WaveFormat")?.GetValue(waveIn));

                if (waveFileWriter == null) return false;

                // Subscribe to DataAvailable event
                var dataAvailableEvent = waveInType.GetEvent("DataAvailable");
                var eventHandler = CreateEventHandler(waveInType, waveFileWriterType, waveFileWriter);
                dataAvailableEvent?.AddEventHandler(waveIn, eventHandler);

                // Start recording
                var startMethod = waveInType.GetMethod("StartRecording", Type.EmptyTypes);
                startMethod?.Invoke(waveIn, null);

                ConsoleUI.WriteColoredLine($"Recording for {durationSeconds} seconds...", ConsoleColor.Yellow);
                await Task.Delay(durationSeconds * 1000);

                // Stop recording
                var stopMethod = waveInType.GetMethod("StopRecording", Type.EmptyTypes);
                stopMethod?.Invoke(waveIn, null);

                // Dispose
                var disposeMethod = waveFileWriterType.GetMethod("Dispose", Type.EmptyTypes);
                disposeMethod?.Invoke(waveFileWriter, null);

                var waveInDisposeMethod = waveInType.GetMethod("Dispose", Type.EmptyTypes);
                waveInDisposeMethod?.Invoke(waveIn, null);

                ConsoleUI.WriteColoredLine($"Recording saved to {outputPath}", ConsoleColor.Green);
                return true;
            }
            catch (Exception ex)
            {
                ConsoleUI.WriteColoredLine($"NAudio recording error: {ex.Message}", ConsoleColor.Red);
                return false;
            }
        }

        private static Delegate CreateEventHandler(Type waveInType, Type waveFileWriterType, object waveFileWriter)
        {
            var dataAvailableEventArgsType = Type.GetType("NAudio.Wave.WaveInEventArgs, NAudio.Core");
            if (dataAvailableEventArgsType == null)
                throw new InvalidOperationException("WaveInEventArgs type not found");

            var delegateType = typeof(EventHandler<>).MakeGenericType(dataAvailableEventArgsType);
            var method = typeof(VoiceRecordingHandler).GetMethod(nameof(OnDataAvailable), 
                System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Static);

            if (method == null)
                throw new InvalidOperationException("OnDataAvailable method not found");

            return Delegate.CreateDelegate(delegateType, method);
        }

        private static void OnDataAvailable(object sender, EventArgs e)
        {
            try
            {
                var eType = e.GetType();
                var bufferProperty = eType.GetProperty("Buffer");
                var countProperty = eType.GetProperty("BytesRecorded");

