        /// <summary>
        /// Plays a recorded voice file
        /// </summary>
        public static async Task PlayRecordedVoiceAsync(string voiceFilePath)
        {
            if (!File.Exists(voiceFilePath))
            {
                ConsoleUI.WriteColoredLine($"Voice file not found: {voiceFilePath}", ConsoleColor.Red);
                return;
            }

            try
            {
                await ConsoleUI.TryPlayGreetingAsync(voiceFilePath);
            }
            catch (Exception ex)
            {
                ConsoleUI.WriteColoredLine($"Playback failed: {ex.Message}", ConsoleColor.Red);
            }
        }

        /// <summary>
        /// Creates a simple WAV file with recorded audio metadata for demonstration
        /// </summary>
        public static void CreateSilentWavFile(string path, int durationSeconds = 1)
        {
            try
            {
                Directory.CreateDirectory(Path.GetDirectoryName(path) ?? "assets");

                byte[] wavHeader = new byte[44];
                int sampleRate = 44100;
                int channels = 1;
                int bitsPerSample = 16;
                int dataSize = (sampleRate * channels * bitsPerSample / 8) * durationSeconds;

                // WAV header
                Array.Copy(new byte[] { 0x52, 0x49, 0x46, 0x46 }, 0, wavHeader, 0, 4); // "RIFF"
                Array.Copy(BitConverter.GetBytes(36 + dataSize), 0, wavHeader, 4, 4);    // File size - 8
                Array.Copy(new byte[] { 0x57, 0x41, 0x56, 0x45 }, 0, wavHeader, 8, 4); // "WAVE"
                Array.Copy(new byte[] { 0x66, 0x6D, 0x74, 0x20 }, 0, wavHeader, 12, 4); // "fmt "
                Array.Copy(BitConverter.GetBytes(16), 0, wavHeader, 16, 4);              // Subchunk1Size
                Array.Copy(BitConverter.GetBytes((short)1), 0, wavHeader, 20, 2);        // AudioFormat (PCM)
                Array.Copy(BitConverter.GetBytes((short)channels), 0, wavHeader, 22, 2); // NumChannels
                Array.Copy(BitConverter.GetBytes(sampleRate), 0, wavHeader, 24, 4);      // SampleRate
                Array.Copy(BitConverter.GetBytes(sampleRate * channels * bitsPerSample / 8), 0, wavHeader, 28, 4); // ByteRate
                Array.Copy(BitConverter.GetBytes((short)(channels * bitsPerSample / 8)), 0, wavHeader, 32, 2);     // BlockAlign
                Array.Copy(BitConverter.GetBytes((short)bitsPerSample), 0, wavHeader, 34, 2);                      // BitsPerSample
                Array.Copy(new byte[] { 0x64, 0x61, 0x74, 0x61 }, 0, wavHeader, 36, 4); // "data"
                Array.Copy(BitConverter.GetBytes(dataSize), 0, wavHeader, 40, 4);        // Subchunk2Size

                using (var file = File.Create(path))
                {
                    file.Write(wavHeader, 0, wavHeader.Length);
                    file.Write(new byte[dataSize], 0, dataSize);
                }
            }
            catch (Exception ex)
            {
                ConsoleUI.WriteColoredLine($"Failed to create WAV file: {ex.Message}", ConsoleColor.Red);
            }
        }
    }
