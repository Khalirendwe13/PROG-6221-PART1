        public static void ClearAndDrawHeader()
        {
            Console.Clear();
            Console.ForegroundColor = ConsoleColor.DarkCyan;
            Console.WriteLine(AsciiArt);
            Console.ResetColor();
            WriteDivider();
        }

        public static void WriteDivider()
        {
            Console.ForegroundColor = ConsoleColor.DarkGray;
            Console.WriteLine(new string('-', 80));
            Console.ResetColor();
        }

        public static void WriteColoredLine(string text, ConsoleColor color)
        {
            Console.ForegroundColor = color;
            Console.WriteLine(text);
            Console.ResetColor();
        }

        public static string ReadNonEmptyLine(string fieldName)
        {
            while (true)
            {
                string? input = Console.ReadLine();
                if (!string.IsNullOrWhiteSpace(input)) return input.Trim();
                WriteColoredLine($"{fieldName} cannot be empty. Please try again:", ConsoleColor.Red);
            }
        }

        /// <summary>
        /// Try to play a WAV greeting file. Playback uses System.Media.SoundPlayer first, with
        /// NAudio as a fallback. The method is safe to call on other platforms and will
        /// silently return if playback is not supported or the file is missing.
        /// </summary>
        public static async Task TryPlayGreetingAsync(string path)
        {
            try
            {
                if (!File.Exists(path))
                {
                    // no audio file, skip
                    return;
                }

                // SoundPlayer is a Windows-specific API; only attempt playback on Windows.
                if (!RuntimeInformation.IsOSPlatform(OSPlatform.Windows))
                {
                    return;
                }

                // Try NAudio first if available (better playback control)
                if (await TryPlayWithNAudioAsync(path))
                {
                    return;
                }

                // Fallback to System.Media.SoundPlayer
                using var player = new SoundPlayer(path);
                player.Play();
                
                // Wait for audio to complete based on file size estimate
                int durationMs = EstimateWavDuration(path);
                await Task.Delay(durationMs);
            }
            catch
            {
                // don't crash if audio playback fails
            }
        }

        /// <summary>
        /// Attempts to play audio using NAudio if available.
        /// </summary>
        private static async Task<bool> TryPlayWithNAudioAsync(string path)
        {
            try
            {
                var waveOutType = Type.GetType("NAudio.Wave.WaveOutEvent, NAudio");
                var audioFileReaderType = Type.GetType("NAudio.Wave.AudioFileReader, NAudio");

                if (waveOutType == null || audioFileReaderType == null)
                {
                    return false;
                }

                // Create WaveOutEvent
                var waveOut = Activator.CreateInstance(waveOutType);
                if (waveOut == null) return false;

                // Create AudioFileReader
                var audioFileReader = Activator.CreateInstance(audioFileReaderType, path);
                if (audioFileReader == null)
                {
                    var disposeMethod = waveOutType.GetMethod("Dispose");
                    disposeMethod?.Invoke(waveOut, null);
                    return false;
                }

                // Set Init method to wire up the reader
                var initMethod = waveOutType.GetMethod("Init", new[] { typeof(object) });
                initMethod?.Invoke(waveOut, new[] { audioFileReader });

                // Play
                var playMethod = waveOutType.GetMethod("Play", Type.EmptyTypes);
                playMethod?.Invoke(waveOut, null);

                // Get duration
                var totalTimeProperty = audioFileReaderType.GetProperty("TotalTime");
                if (totalTimeProperty?.GetValue(audioFileReader) is TimeSpan totalTime)
                {
                    await Task.Delay(totalTime.Add(TimeSpan.FromMilliseconds(500)));
                }
                else
                {
                    await Task.Delay(5000);
                }

                // Cleanup
                var stopMethod = waveOutType.GetMethod("Stop", Type.EmptyTypes);
                stopMethod?.Invoke(waveOut, null);

                var waveOutDisposeMethod = waveOutType.GetMethod("Dispose");
                waveOutDisposeMethod?.Invoke(waveOut, null);

                var audioReaderDisposeMethod = audioFileReaderType.GetMethod("Dispose");
                audioReaderDisposeMethod?.Invoke(audioFileReader, null);

                return true;
            }
            catch
            {
                return false;
            }
        }

        /// <summary>
        /// Estimates WAV file duration based on file size and standard WAV format assumptions.
        /// </summary>
        private static int EstimateWavDuration(string wavPath)
        {
            try
            {
                var fileInfo = new FileInfo(wavPath);
                // Standard WAV: 44100 Hz, 16-bit, mono = 88,200 bytes per second
                // Rough estimate: fileSize / 88200 * 1000 + buffer
                long dataSize = fileInfo.Length - 44; // subtract WAV header
                if (dataSize > 0)
                {
                    double durationSeconds = dataSize / 88200.0;
                    return Math.Max(1000, (int)(durationSeconds * 1000 + 500)); // Add 500ms buffer
                }
            }
            catch
            {
                // ignore calculation errors
            }

            return 2000; // Default 2 second fallback
        }

        public static void TypeWrite(string text, int msDelay = 20)
        {
            foreach (char c in text)
            {
                Console.Write(c);
                System.Threading.Thread.Sleep(msDelay);
            }
        }

        public static async Task TypeWriteAsync(string text, int msDelay = 20)
        {
            foreach (char c in text)
            {
                Console.Write(c);
                await Task.Delay(msDelay);
            }
        }
    }
}
